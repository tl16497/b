            <button type="submit">Submit</button>
            </div>
        </form>
        </div>
        <script>
            const form = document.getElementById("register");
            form.addEventListener("submit", function(e){
                e.preventDefault();

                let lastname = document.getElementById("lastname").value.trim();
                let email = document.getElementById("email").value.trim();
                let phone = document.getElementById("phone").value.trim();
                let courses = document.getElementById("courses-select").value.trim();
                let time = document.getElementById("time").value;

                document.getElementById("name-error").innerHTML = "";
                document.getElementById("email-error").innerHTML = "";
                document.getElementById("phone-error").innerHTML = "";
                document.getElementById("courses-error").innerHTML = "";
                document.getElementById("time-error").innerHTML = "";

                let check = true;

                if(lastname == "") {
                    document.getElementById("name-error").innerHTML = "Vui lòng nhập thông tin";
                    check = false;
                }
                if(email == "" || !email.includes("@")) {
                    document.getElementById("email-error").innerHTML = "Email không hợp lệ";
                    check = false;
                }
                if(phone == "" || isNaN(phone)) {
                    document.getElementById("phone-error").innerHTML = "Số điện thoại không hợp lệ";
                    check = false;
                }
                if(courses == "") {
                    document.getElementById("courses-error").innerHTML = "Vui lòng chọn khóa học";
                    check = false;
                }
                if(time == "") {
                    document.getElementById("time-error").innerHTML = "Vui lòng chọn thời gian học";
                    check = false;
                }
                if(check) {
                    alert("Đăng ký thành công!");
                }
            })
        </script>
    </body>
</html>     
