<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Câu 3 - JSON và while</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f5f7fb;
        }

        #course-list {
            display: grid;
            gap: 14px;
        }

        .course-box {
            background: #ffffff;
            border: 1px solid #d9e2ec;
            border-radius: 8px;
            padding: 14px;
        }

        .course-box h3 {
            margin-top: 0;
            color: #1565c0;
        }
    </style>
</head>
<body>
    <h1>Câu 3 - Danh sách khóa học từ JSON</h1>
    <div id="course-list"></div>

    <script>
        const coursesJson = `[
            {
                "tenKhoaHoc": "Tiếng Anh Giao Tiếp Cơ Bản",
                "moTa": "Dành cho người mới bắt đầu, luyện phản xạ nghe nói theo tình huống thực tế.",
                "hocPhi": "2.500.000 VNĐ",
                "khaiGiang": "10/06/2026"
            },
            {
                "tenKhoaHoc": "IELTS Foundation 4.0 - 5.5",
                "moTa": "Xây nền tảng ngữ pháp, từ vựng và kỹ năng làm bài IELTS.",
                "hocPhi": "3.200.000 VNĐ",
                "khaiGiang": "15/06/2026"
            },
            {
                "tenKhoaHoc": "TOEIC 450+",
                "moTa": "Tập trung từ vựng công sở, cấu trúc đề TOEIC và mẹo làm bài.",
                "hocPhi": "2.800.000 VNĐ",
                "khaiGiang": "20/06/2026"
            },
            {
                "tenKhoaHoc": "Phát Âm Chuẩn Với Giáo Viên Bản Ngữ",
                "moTa": "Sửa lỗi phát âm, luyện trọng âm và ngữ điệu chuẩn quốc tế.",
                "hocPhi": "3.500.000 VNĐ",
                "khaiGiang": "01/07/2026"
            }
        ]`;

        const courses = JSON.parse(coursesJson);
        const list = document.getElementById("course-list");
        var i = 0;

        while (i < courses.length) {
            const c = courses[i];
            const div = document.createElement("div");
            div.className = "course-box";
            div.innerHTML = `
                <h3>${c.tenKhoaHoc}</h3>
                <p><strong>Mô tả:</strong> ${c.moTa}</p>
                <p><strong>Học phí:</strong> ${c.hocPhi}</p>
                <p><strong>Khai giảng:</strong> ${c.khaiGiang}</p>
            `;
            list.appendChild(div);
            i++;
        }
    </script>
</body>
